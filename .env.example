# Neon Postgres connection string
DATABASE_URL=
# OpenAI API key — server-side only, used for cutouts + tagging (and renders/stylist later)
OPENAI_API_KEY=
# Set to 1 to serve canned AI fixtures instead of calling OpenAI/Blob (dev + all tests)
MOCK_AI=1
# Vercel Blob read-write token (auto-set on Vercel; locally: npx vercel env pull .env.local — pull OVERWRITES the file, re-check MOCK_AI=1 afterwards)
BLOB_READ_WRITE_TOKEN=
# Pinterest app credentials — server-side only, power the Explore feed
# (developers.pinterest.com → your app → Trial access). When PINTEREST_APP_ID
# is set, Explore talks to the real Pinterest API even under MOCK_AI=1
# (leave unset to keep the canned mock pins).
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
